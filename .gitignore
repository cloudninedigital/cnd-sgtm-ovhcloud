# Terraform state and lock files – never commit these
*.tfstate
*.tfstate.*
.terraform/

# Local variable overrides – may contain secrets
terraform.tfvars
*.auto.tfvars

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Generated plan files
*.tfplan

# Environment-specific variable files
*.env
.env

# macOS metadata
.DS_Store

# Editor directories
.idea/
.vscode/
*.swp
*.swo
